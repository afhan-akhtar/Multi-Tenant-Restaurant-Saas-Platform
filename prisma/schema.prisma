// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////// ENUMS ////////////////////

enum TenantStatus {
  PENDING // Awaiting Super Admin approval (self-registration)
  ACTIVE
  INACTIVE
  BLOCKED
}

enum TenantAdminStatus {
  ACTIVE
  INACTIVE

  @@map("StaffStatus")
}

enum OrderType {
  DINE_IN
  TAKEAWAY
}

enum OrderStatus {
  OPEN
  CONFIRMED
  PREPARING
  READY
  PACK
  COMPLETED
  PARTIAL_REFUND
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  PARTIALLY_REFUNDED
  REFUNDED
}

enum PaymentMethod {
  CASH
  STRIPE
  PAYPAL
  CARD
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

enum KDSStatus {
  CREATED
  COOKING
  READY
  DISPATCHED
}

enum DeviceType {
  POS
  KDS
}

enum DeviceStatus {
  ACTIVE
  DISABLED
}

enum KDSStationType {
  MAIN
  EXPEDITOR
  GRILL
  FRYER
  DRINKS
  PACKING
  DESSERT
  CUSTOM
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  GRACE_PERIOD
  PAST_DUE
  EXPIRED
  CANCELLED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum BillingInvoiceStatus {
  OPEN
  PAID
  VOID
  OVERDUE
}

enum BillingPaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum BillingPaymentMethod {
  MANUAL
  STRIPE
  CARD
  BANK_TRANSFER
  CASH
}

enum PlanChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

//////////////////// TABLES ////////////////////

model SuperAdmin {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Tenant {
  id        Int          @id @default(autoincrement())
  name      String
  subdomain String       @unique
  country   String       @default("") // Primary country (multi-country tenants)
  logoUrl   String? // Optional logo for receipts and branding
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now())

  fiskalyConfig      TenantFiskalyConfig?
  branches           Branch[]
  roles              Role[]
  tenantAdmins       TenantAdmin[]
  subscription       TenantSubscription[]
  categories         Category[]
  products           Product[]
  addonGroups        AddonGroup[]
  diningTables       DiningTable[]
  sessions           Session[]
  customers          Customer[]
  segments           Segment[]
  emailCampaigns     EmailCampaign[]
  orders             Order[]
  refunds            Refund[]
  billingInvoices    BillingInvoice[]
  billingPayments    BillingPayment[]
  planChangeRequests SubscriptionPlanChangeRequest[]
  cashbookEntries    CashbookEntry[]
  tseQueues          TSEQueue[]
  auditLogs          AuditLog[]
  deviceTokens       DeviceToken[]
}

model TenantFiskalyConfig {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @unique
  apiKey    String
  apiSecret String
  tssId     String?
  clientId  String?
  adminPuk  String? // Store for PIN recovery; keep secure
  vatId     String? // Optional: cached VAT ID for receipts
  taxNumber String? // Optional: cached Tax Number for receipts
  wIdNr     String? // Optional: cached W-IdNr. for receipts
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// Platform default: TSS+client for env credentials (created via POST /api/tse/setup)
model FiskalyPlatformConfig {
  id        Int      @id @default(autoincrement())
  apiKey    String   @unique // matches FISKALY_API_KEY
  tssId     String
  clientId  String
  adminPuk  String?
  updatedAt DateTime @updatedAt
}

model SubscriptionPlan {
  id                  Int                             @id @default(autoincrement())
  code                String?                         @unique
  name                String
  description         String?
  billingInterval     BillingInterval                 @default(MONTHLY)
  monthlyPrice        Decimal
  commissionPercent   Decimal
  trialDays           Int                             @default(0)
  graceDays           Int                             @default(0)
  sortOrder           Int                             @default(0)
  features            Json
  tenantSubscriptions TenantSubscription[]
  invoices            BillingInvoice[]
  requestedChanges    SubscriptionPlanChangeRequest[]
}

model TenantSubscription {
  id                Int                @id @default(autoincrement())
  tenantId          Int
  planId            Int
  status            SubscriptionStatus
  startDate         DateTime
  endDate           DateTime
  trialStartDate    DateTime?
  trialEndDate      DateTime?
  gracePeriodEndsAt DateTime?
  nextBillingDate   DateTime?
  autoRenew         Boolean            @default(true)
  cancelAtPeriodEnd Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  tenant             Tenant                          @relation(fields: [tenantId], references: [id])
  plan               SubscriptionPlan                @relation(fields: [planId], references: [id])
  invoices           BillingInvoice[]
  planChangeRequests SubscriptionPlanChangeRequest[]

  @@index([tenantId])
}

model BillingInvoice {
  id             Int                  @id @default(autoincrement())
  tenantId       Int
  subscriptionId Int
  planId         Int
  invoiceNumber  String               @unique
  status         BillingInvoiceStatus @default(OPEN)
  issuedAt       DateTime             @default(now())
  dueDate        DateTime
  periodStart    DateTime
  periodEnd      DateTime
  subtotal       Decimal
  taxAmount      Decimal              @default(0)
  totalAmount    Decimal
  currency       String               @default("EUR")
  lineItems      Json
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  tenant       Tenant             @relation(fields: [tenantId], references: [id])
  subscription TenantSubscription @relation(fields: [subscriptionId], references: [id])
  plan         SubscriptionPlan   @relation(fields: [planId], references: [id])
  payments     BillingPayment[]

  @@index([tenantId, status])
  @@index([subscriptionId, periodStart, periodEnd])
}

model BillingPayment {
  id        Int                  @id @default(autoincrement())
  invoiceId Int
  tenantId  Int
  amount    Decimal
  method    BillingPaymentMethod @default(MANUAL)
  status    BillingPaymentStatus @default(SUCCEEDED)
  paidAt    DateTime             @default(now())
  reference String?
  notes     String?
  createdAt DateTime             @default(now())

  invoice BillingInvoice @relation(fields: [invoiceId], references: [id])
  tenant  Tenant         @relation(fields: [tenantId], references: [id])

  @@index([tenantId, paidAt])
  @@index([invoiceId, status])
}

model SubscriptionPlanChangeRequest {
  id                    Int                     @id @default(autoincrement())
  tenantId              Int
  currentSubscriptionId Int?
  requestedPlanId       Int
  status                PlanChangeRequestStatus @default(PENDING)
  message               String?
  reviewedNote          String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  reviewedAt            DateTime?

  tenant              Tenant              @relation(fields: [tenantId], references: [id])
  currentSubscription TenantSubscription? @relation(fields: [currentSubscriptionId], references: [id])
  requestedPlan       SubscriptionPlan    @relation(fields: [requestedPlanId], references: [id])

  @@index([tenantId, status])
  @@index([requestedPlanId, status])
}

model Branch {
  id       Int    @id @default(autoincrement())
  tenantId Int
  name     String
  address  String
  city     String
  country  String

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  tenantAdmins TenantAdmin[]
  diningTables DiningTable[]
  sessions     Session[]
  orders       Order[]
  kdsScreens   KDSScreen[]
  deviceTokens DeviceToken[]

  @@index([tenantId])
}

model Role {
  id       Int    @id @default(autoincrement())
  tenantId Int
  name     String

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  tenantAdmins    TenantAdmin[]
  rolePermissions RolePermission[]

  @@index([tenantId])
}

model Permission {
  id              Int              @id @default(autoincrement())
  code            String           @unique
  rolePermissions RolePermission[]
}

model RolePermission {
  id           Int @id @default(autoincrement())
  roleId       Int
  permissionId Int

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

// Tenant admin / user accounts for each restaurant (per-tenant admins)
model TenantAdmin {
  id           Int               @id @default(autoincrement())
  tenantId     Int
  branchId     Int
  roleId       Int
  name         String
  email        String
  passwordHash String
  refundPinHash String?
  status       TenantAdminStatus @default(ACTIVE)
  createdAt    DateTime          @default(now())

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  branch    Branch     @relation(fields: [branchId], references: [id])
  role      Role       @relation(fields: [roleId], references: [id])
  sessions  Session[]  @relation("WaiterSessions")
  refunds   Refund[]
  auditLogs AuditLog[]

  @@index([tenantId])
  @@map("Staff")
}

model Category {
  id       Int    @id @default(autoincrement())
  tenantId Int
  name     String
  parentId Int?

  tenant   Tenant     @relation(fields: [tenantId], references: [id])
  parent   Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToCategory")

  products Product[]

  @@index([tenantId])
}

model Product {
  id           Int     @id @default(autoincrement())
  tenantId     Int
  categoryId   Int
  name         String
  description  String
  plu          String
  basePrice    Decimal
  taxRate      Decimal
  imageUrl     String?
  allergens    Json?
  dietaryFlags Json?
  isActive     Boolean @default(true)
  kdsStation   KDSStationType?

  tenant     Tenant           @relation(fields: [tenantId], references: [id])
  category   Category         @relation(fields: [categoryId], references: [id])
  variants   ProductVariant[]
  orderItems OrderItem[]

  @@index([tenantId])
}

model ProductVariant {
  id        Int     @id @default(autoincrement())
  productId Int
  name      String
  price     Decimal

  product Product @relation(fields: [productId], references: [id])
}

model AddonGroup {
  id        Int    @id @default(autoincrement())
  tenantId  Int
  name      String
  minSelect Int
  maxSelect Int

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  addonItems AddonItem[]
}

model AddonItem {
  id      Int     @id @default(autoincrement())
  groupId Int
  name    String
  price   Decimal

  group AddonGroup @relation(fields: [groupId], references: [id])
}

model DiningTable {
  id       Int         @id @default(autoincrement())
  tenantId Int
  branchId Int
  name     String
  seats    Int
  status   TableStatus

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  branch   Branch    @relation(fields: [branchId], references: [id])
  sessions Session[]
  orders   Order[]
}

model Session {
  id       Int       @id @default(autoincrement())
  tenantId Int
  branchId Int
  tableId  Int
  waiterId Int
  openedAt DateTime
  closedAt DateTime?

  tenant Tenant      @relation(fields: [tenantId], references: [id])
  branch Branch      @relation(fields: [branchId], references: [id])
  table  DiningTable @relation(fields: [tableId], references: [id])
  waiter TenantAdmin @relation("WaiterSessions", fields: [waiterId], references: [id])
  orders Order[]
}

model Customer {
  id            Int    @id @default(autoincrement())
  tenantId      Int
  name          String
  phone         String
  email         String
  loyaltyPoints Int    @default(0)

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  orders Order[]
}

model Segment {
  id       Int    @id @default(autoincrement())
  tenantId Int
  name     String
  rules    Json

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model EmailCampaign {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  subject     String
  content     Json
  scheduledAt DateTime

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model Order {
  id             Int         @id @default(autoincrement())
  tenantId       Int
  branchId       Int
  sessionId      Int
  tableId        Int
  customerId     Int
  orderNumber    String
  /// Idempotency key from offline POS queue (UUID); prevents duplicate Order rows on sync retry / double POST.
  offlineCheckoutId String? @db.VarChar(64)
  orderType      OrderType
  status         OrderStatus
  subtotal       Decimal
  taxAmount      Decimal
  discountAmount Decimal
  tipAmount      Decimal
  totalAmount    Decimal     @default(0)
  grandTotal     Decimal
  refundedAmount Decimal     @default(0)
  lastRefundAt   DateTime?
  createdAt      DateTime    @default(now())

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  branch          Branch           @relation(fields: [branchId], references: [id])
  session         Session          @relation(fields: [sessionId], references: [id])
  table           DiningTable      @relation(fields: [tableId], references: [id])
  customer        Customer         @relation(fields: [customerId], references: [id])
  orderItems      OrderItem[]
  payments        Payment[]
  refunds         Refund[]
  tseTransactions TSETransaction[]

  @@unique([tenantId, offlineCheckoutId])
}

model OrderItem {
  id          Int         @id @default(autoincrement())
  orderId     Int
  productId   Int
  productName String
  name        String?
  unitPrice   Decimal
  price       Decimal?
  taxRate     Decimal
  quantity    Int
  totalAmount Decimal
  status      OrderStatus
  refunded    Boolean     @default(false)

  order    Order     @relation(fields: [orderId], references: [id])
  product  Product   @relation(fields: [productId], references: [id])
  refunds  Refund[]
  kdsItems KDSItem[]
}

model Payment {
  id          Int           @id @default(autoincrement())
  orderId     Int
  method      PaymentMethod
  status      PaymentStatus
  amount      Decimal
  refundedAmount Decimal    @default(0)
  refundedAt   DateTime?
  transactionId String?
  providerRef String?
  metadata    Json?
  createdAt   DateTime      @default(now())

  order   Order    @relation(fields: [orderId], references: [id])
  refunds Refund[]
}

model Refund {
  id               Int           @id @default(autoincrement())
  tenantId         Int
  orderId          Int
  paymentId        Int?
  itemId           Int?
  actorId          Int?
  batchKey         String?
  amount           Decimal
  reason           String
  paymentMethod    PaymentMethod?
  refundType       String        @default("ITEM")
  externalRefundId String?
  metadata         Json?
  createdAt        DateTime      @default(now())

  tenant Tenant       @relation(fields: [tenantId], references: [id])
  order  Order        @relation(fields: [orderId], references: [id])
  payment Payment?    @relation(fields: [paymentId], references: [id])
  item   OrderItem?   @relation(fields: [itemId], references: [id])
  actor  TenantAdmin? @relation(fields: [actorId], references: [id])

  @@index([tenantId, createdAt])
  @@index([orderId, createdAt])
  @@index([batchKey])
  @@index([itemId])
  @@index([paymentId])
}

model TSETransaction {
  id              Int      @id @default(autoincrement())
  orderId         Int?
  cashbookEntryId Int?     @unique
  transactionType String   @default("ORDER") // ORDER, CANCELLATION, PAYMENT, CASH_DEPOSIT, CASH_WITHDRAWAL
  signature       String
  fiskalyTxId     String
  signedAt        DateTime
  rawPayload      Json? // Audit trail

  order         Order?         @relation(fields: [orderId], references: [id])
  cashbookEntry CashbookEntry? @relation(fields: [cashbookEntryId], references: [id])

  @@index([orderId])
  @@index([cashbookEntryId])
}

model TSEQueue {
  id         Int       @id @default(autoincrement())
  tenantId   Int
  entityType String // ORDER, CASH_DEPOSIT, CASH_WITHDRAWAL
  entityId   Int
  payload    Json
  status     String    @default("PENDING") // PENDING, MIGRATED, FAILED
  errorMsg   String?
  createdAt  DateTime  @default(now())
  migratedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
}

model CashbookEntry {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  type        String
  amount      Decimal
  referenceId Int?
  createdAt   DateTime @default(now())

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  tseTransaction TSETransaction?
}

model KDSScreen {
  id          Int            @id @default(autoincrement())
  branchId    Int
  name        String
  code        String?
  stationType KDSStationType @default(MAIN)
  isActive    Boolean        @default(true)
  isDefault   Boolean        @default(false)

  branch       Branch        @relation(fields: [branchId], references: [id])
  kdsItems     KDSItem[]
  deviceTokens DeviceToken[]

  @@unique([branchId, name])
  @@index([branchId, stationType, isActive])
}

model KDSItem {
  id          Int       @id @default(autoincrement())
  orderItemId Int
  screenId    Int
  status      KDSStatus

  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
  screen    KDSScreen @relation(fields: [screenId], references: [id])
}

model DeviceToken {
  id         Int          @id @default(autoincrement())
  tenantId   Int
  branchId   Int?
  screenId   Int?
  name       String
  deviceType DeviceType
  status     DeviceStatus @default(ACTIVE)
  tokenHash  String       @unique
  lastSeenAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch?    @relation(fields: [branchId], references: [id], onDelete: SetNull)
  screen KDSScreen? @relation(fields: [screenId], references: [id], onDelete: SetNull)

  @@unique([tenantId, name])
  @@index([tenantId, deviceType])
  @@index([branchId])
  @@index([screenId])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  tenantId   Int
  actorId    Int
  action     String
  entityType String
  entityId   Int
  createdAt  DateTime @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  tenantAdmin TenantAdmin @relation(fields: [actorId], references: [id])
}
